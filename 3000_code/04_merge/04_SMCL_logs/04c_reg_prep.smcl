. *** multi-event-depts ***

. 
. egen temp_tag=tag(num_dept reg_edate0) if (date==reg_edate0)

. 
. bysort num_dept: egen num_events=sum(temp_tag) 

. 
. gen multi_dept=(num_events>1)

. 
. drop temp_tag

. 
. 
