. * GENERATING UNION/INTERSECTION SCRUTINY ***

. 
. *gen n_scr=scr_nl

. 
. *gen d_scr=scr_dl

. 
. *gen or_scr=0

. 
. *replace or_scr=1 if (scr_nl==1) | (scr_dl==1)

. 
. *replace or_scr=2 if (scr_nl==2) | (scr_dl==2)

. 
. *gen and_scr=0

. 
. *replace and_scr=1 if (scr_nl==1) & (scr_dl==1)

. 
. *replace and_scr=2 if (scr_nl==2) & (scr_dl==2)

. 
