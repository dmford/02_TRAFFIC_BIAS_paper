. bysort st_dept: egen reg_event_count0 = sum(reg_event_tag0)

. 
. bysort st_dept: egen reg_event_count1 = sum(reg_event_tag1)

. 
. bysort st_dept: egen reg_event_count2 = sum(reg_event_tag2)

