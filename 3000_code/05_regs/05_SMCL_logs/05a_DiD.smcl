{txt}141{com}. 
. display " `variant': Heterogeneity Check"
{txt}142{com}. 
. xtreg `o' `xit' `x_tbar' `x_ibar' `x_t_diff' `x_i_diff' `aweight' if (e_`o'_main==1) `ifs1', fe vce(cl num_dept)
{txt}143{com}. 
. est save "4000_outputs/`k'_days/eq1/`o'/DiD_`variant'`suffix'", replace
{txt}144{com}. 
. gen e_`o'_`variant' = (e(sample)==1)
{txt}145{com}. 
. 
. 
. * joint F-test, to see if new interactions are relevant: 
. 
. test `x_t_diff' 
{txt}146{com}. 
. test `x_i_diff' 
{txt}147{com}. 
. test `x_t_diff' `x_i_diff' 
{txt}148{com}. 
. 
. 
. save "2000_data/500_working/`k'_days/eq1/`o'/e_DiD`suffix'.dta", replace
{txt}149{com}. 
. {c )-}

