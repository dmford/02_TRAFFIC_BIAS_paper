. 
. 
. local j = 1

. 
. local J = _N

. 
. 
. 
. foreach orig_file of local SparseDrop {
  2. 
. display ""
  3. 
. display "#`j'/`J' | `orig_file'"
  4. 
. local ++j
  5. 
. use "`orig_file'", replace
  6. 
. local K = c(k)
  7. 
. foreach threshold in 100 {
  8. 
. foreach var of varlist _all {
  9. 
