 10. 
. if (a < `threshold') display "dropping `var': `: var label `var''"
 11. 
. if (a < `threshold') drop `var'
 12. 
. drop a
 13. 
. }
 14. 
. display "Variables remaining for threshold=`threshold': "c(k) "/`K'"
 15. 
. }
 16. 
. local save = subinstr("`orig_file'", "100_original\40_LEMAS_orig", "200_raw\4
> 0_LEMAS_raw", .)
 17. 
. save "`save'", replace
 18. 
