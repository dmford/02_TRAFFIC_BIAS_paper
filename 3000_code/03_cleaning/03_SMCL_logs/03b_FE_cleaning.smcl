{txt}
{com}. 
. ****************************************************************************************************
. 
. * renaming things ahead of merge
. rename dept_name department_name
{res}{txt}
{com}. replace department_name = strtrim(department_name)
{txt}(3,194 real changes made)

{com}. replace department_name = stritrim(department_name)
{txt}(0 real changes made)

{com}. rename city fe_city
{res}{txt}
{com}. rename county_name fe_county_name
{res}{txt}
{com}. 
. * FE dates --> shooting_date
. gen shooting_date = date(fe_date, "MDY")
{txt}
{com}. drop fe_date
{txt}
{com}. format %td shooting_date
{txt}
{com}. 
. * generating dept, state-specific unique department names: = state + _ + dept
. gen st_dept = state + "_" + department_name
{txt}
{com}. 
. * re-framing FE's fe_subject_race variable: 
. rename fe_subject_race orig_fe_subject_race
{res}{txt}
{com}. gen fe_subject_race = 1 if inlist(orig_fe_subject_race, "European-American/White", "European-American/European-American/White", "european-American/White", "Christopher Anthony Alexander")
{txt}(22,627 missing values generated)

{com}. replace fe_subject_race = 2 if inlist(orig_fe_subject_race, "African-American/Black", "African-American/Black African-American/Black Not imputed")
{txt}(7,442 real changes made)

{com}. replace fe_subject_race = 3 if inlist(orig_fe_subject_race, "Hispanic/Latino")
{txt}(4,446 real changes made)

{com}. replace fe_subject_race = 4 if inlist(orig_fe_subject_race, "Asian/Pacific Islander")
{txt}(511 real changes made)

{com}. replace fe_subject_race = 5 if inlist(orig_fe_subject_race, "Native American/Alaskan")
{txt}(352 real changes made)

{com}. replace fe_subject_race = 6 if inlist(orig_fe_subject_race, "Middle Eastern")
{txt}(61 real changes made)

{com}. replace fe_subject_race = 8 if inlist(orig_fe_subject_race, "Race unspecified")
{txt}(9,815 real changes made)

{com}. gen fe_subject_race_flag = (fe_subject_race == 8 | fe_subject_race == 9)
{txt}
{com}. label values fe_subject_race races
{txt}
{com}. drop orig_fe_subject_race
{txt}
{com}. 
. * re-framing fe_highest_force variable: 
. label define force_levels 1 "Gunshot" 2 "Vehicle" 3 "Tasered" 4 "Medical emergency" 5 "Asphyxiated/Restrained" 6 "Drowned" 7 "Beaten/Bludgeoned with instrument" 8 "Drug overdose" 9 "Fell from a height" 10 "Stabbed" 11 "Burned/Smoke inhalation" 12 "Chemical agent/Pepper spray" 13 "Less-than-lethal force" 14 "Other" 99 "Undetermined"
{txt}
{com}. replace fe_highest_force = "Asphyxiated/Restrained" if fe_highest_force == "Asphyxiation/Restrain" | fe_highest_force == "Asphyxiation/Restrained" | fe_highest_force == "Restrain/Asphyxiation"
{txt}(4 real changes made)

{com}. rename fe_highest_force orig_fe_highest_force
{res}{txt}
{com}. gen fe_highest_force = .
{txt}(34,612 missing values generated)

{com}. replace fe_highest_force = 1 if orig_fe_highest_force == "Gunshot"
{txt}(24,696 real changes made)

{com}. replace fe_highest_force = 2 if orig_fe_highest_force == "Vehicle"
{txt}(7,047 real changes made)

{com}. replace fe_highest_force = 3 if orig_fe_highest_force == "Tasered"
{txt}(1,000 real changes made)

{com}. replace fe_highest_force = 4 if orig_fe_highest_force == "Medical emergency"
{txt}(418 real changes made)

{com}. replace fe_highest_force = 5 if orig_fe_highest_force == "Asphyxiated/Restrained"
{txt}(383 real changes made)

{com}. replace fe_highest_force = 6 if orig_fe_highest_force == "Drowned"
{txt}(230 real changes made)

{com}. replace fe_highest_force = 7 if orig_fe_highest_force == "Beaten/Bludgeoned with instrument"
{txt}(197 real changes made)

{com}. replace fe_highest_force = 8 if orig_fe_highest_force == "Drug overdose"
{txt}(190 real changes made)

{com}. replace fe_highest_force = 9 if orig_fe_highest_force == "Fell from a height"
{txt}(100 real changes made)

{com}. replace fe_highest_force = 10 if orig_fe_highest_force == "Stabbed"
{txt}(64 real changes made)

{com}. replace fe_highest_force = 11 if orig_fe_highest_force == "Burned/Smoke inhalation"
{txt}(49 real changes made)

{com}. replace fe_highest_force = 12 if orig_fe_highest_force == "Chemical agent/Pepper spray"
{txt}(37 real changes made)

{com}. replace fe_highest_force = 13 if orig_fe_highest_force == "Less-than-lethal force"
{txt}(1 real change made)

{com}. replace fe_highest_force = 14 if orig_fe_highest_force == "Other"
{txt}(91 real changes made)

{com}. replace fe_highest_force = 99 if orig_fe_highest_force == "Undetermined"
{txt}(106 real changes made)

{com}. label values fe_highest_force force_levels
{txt}
{com}. drop orig_fe_highest_force
{txt}
{com}. 
. * re-framing FE's fe_armed variable: 
. rename fe_armed orig_fe_armed
{res}{txt}
{com}. gen fe_armed = .
{txt}(34,612 missing values generated)

{com}. replace fe_armed = 0 if inlist(orig_fe_armed, "Unarmed", "None")
{txt}(6,468 real changes made)

{com}. replace fe_armed = 1 if inlist(orig_fe_armed, "Armed", "Arrmed")
{txt}(11,770 real changes made)

{com}. replace fe_armed = 8 if orig_fe_armed == "Uncertain"
{txt}(432 real changes made)

{com}. label values fe_armed false_true_unk_na
{txt}
{com}. drop orig_fe_armed
{txt}
{com}. 
. * re-framing FE's fe_subject_age variable: 
. * NOTE: assuming dist'n of 18-25 y/o's is uniform, replacing with 21.5, the median. 
. gen fe_subject_age_18_25 = (fe_subject_age == "18-25")
{txt}
{com}. replace fe_subject_age = "21.5" if fe_subject_age == "18-25"
{txt}(2 real changes made)

{com}. replace fe_subject_age = "999" if fe_subject_age == "NA"
{txt}(0 real changes made)

{com}. destring fe_subject_age, replace
{txt}fe_subject_age: all characters numeric; {res}replaced {txt}as {res}double
{txt}(1336 missing values generated)
{res}{txt}
{com}. gen fe_subject_age_nines = (fe_subject_age == 999)
{txt}
{com}. egen temp_age = max(fe_subject_age_nines) 
{txt}
{com}. if temp_age == 0 drop fe_subject_age_nines
{txt}
{com}. drop temp_age
{txt}
{com}. 
. * re-framing FE's fe_subject_sex variable: (1=male, 2=female, 3=trans, 9=NA)
. rename fe_subject_gender fe_subject_sex
{res}{txt}
{com}. label define sex 1 "male" 2 "female" 3 "transgender" 9 "NA"
{txt}
{com}. replace fe_subject_sex = "1" if fe_subject_sex == "Male"
{txt}(31,165 real changes made)

{com}. replace fe_subject_sex = "2" if fe_subject_sex == "Female"
{txt}(3,286 real changes made)

{com}. replace fe_subject_sex = "3" if fe_subject_sex == "Transgender"
{txt}(25 real changes made)

{com}. destring fe_subject_sex, replace
{txt}fe_subject_sex: all characters numeric; {res}replaced {txt}as {res}byte
{txt}(136 missing values generated)
{res}{txt}
{com}. label values fe_subject_sex sex
{txt}
{com}. gen fe_subject_sex_flag = (fe_subject_sex == 9)
{txt}
{com}. 
