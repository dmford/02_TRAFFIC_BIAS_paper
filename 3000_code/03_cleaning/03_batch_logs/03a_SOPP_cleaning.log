. * dept non-unique, (state+dept) should be unique --> st_dept

. 
. gen st_dept = state + "_" + department_name

. 
. 
. 
. * SOPP dates --> stop_date

. 
. gen stop_date = date(date, "YMD")

. 
. drop date

. 
. format %td stop_date

. 
. 
. 
. * Assn: if max=min, no variation in days (months)--> monthly (annual) reporte
> r

. 
. gen stop_day = day(stop_date)

. 
. bysort st_dept: egen max_stop_day = max(stop_day)

. 
. bysort st_dept: egen min_stop_day = min(stop_day)

. 
. gen temp_stop_day_diff = max_stop_day - min_stop_day

. 
. gen rep_monthly = (temp_stop_day_diff == 0)

. 
. drop temp_* stop_day max_stop_day min_stop_day

. 
. gen stop_month = month(stop_date)

. 
. bysort st_dept: egen max_stop_month = max(stop_month)

. 
. bysort st_dept: egen min_stop_month = min(stop_month)

. 
. gen temp_stop_month_diff = max_stop_month - min_stop_month

. 
. gen rep_annually = (temp_stop_month_diff == 0)

. 
. drop temp_* stop_month max_stop_month min_stop_month 

. 
