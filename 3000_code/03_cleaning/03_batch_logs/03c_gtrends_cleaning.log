. replace date = date[_n-1]+1 if (_n>1)
 17. 
. gen event = (date == temp)
 18. 
. format date %td
 19. 
. drop temp day
 20. 
. describe, varlist
 21. 
. local var3 : word 1 of `r(varlist)'
 22. 
. gen name = "`var3'"
