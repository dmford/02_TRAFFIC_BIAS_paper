. 
. 
. * this loop for trends without search data (too few): 
. 
. if (_N==0) {
  4. 
. set obs 270
  5. 
. gen fe_id = substr("`file'",74,5)
  6. 
. replace fe_id = subinstr(fe_id,"_","",.)
  7. 
. destring fe_id, replace
  8. 
. if (fe_id < 10000) {
  9. 
. gen temp = substr("`file'",79,5)
 10. 
. }
 11. 
. else {
 12. 
. gen temp = substr("`file'",80,5)
 13. 
. }
 14. 
. destring temp, replace
